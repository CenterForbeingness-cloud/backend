# Copy this file to .env and fill in values
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
CHAT_MODEL_SCHEDULE=gpt-4o-mini
SCHEDULE_HISTORY_MESSAGES=6
SCHEDULE_SCRIPT_ENGINE=true
PORT=8000

# Supabase
SUPABASE_URL=
# Use service-role key only for backend — NEVER expose in frontend
SUPABASE_KEY=
SUPABASE_DB_URL=
SUPABASE_JWT_SECRET=

# Auth / security
AUTH_ENFORCED=false
# Comma-separated allowed origins (leave empty to allow all in dev)
CORS_ORIGINS=63b0d37b75e3ac07f6490db548b988b1e99912fe803a5b3513ca738ac11e94fec971b9b9d9173b27eb18730e0e2005525998e9fe34c276e3aa7aff4ba3b6b62a
# Set true to require chat-scoped tokens on /chat endpoints.
CHAT_TOKEN_ENFORCED=false
# Optional override; defaults to SUPABASE_JWT_SECRET when empty.
CHAT_TOKEN_SECRET=
# 900 = 15 minutes
CHAT_TOKEN_TTL_SECONDS=900

# IP rate limiting (set RATE_LIMIT_ENABLED=true in production)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_SESSIONS=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_BILLING=15/minute

# RAG
RAG_ENABLED=false
RAG_TOP_K=3

# Voice (MVP Launch) — POST /chat/voice
VOICE_ENABLED=false
VOICE_MAX_RECORDING_SEC=90
VOICE_DAILY_SECONDS_CAP=600
WHISPER_MODEL=whisper-1
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_DEFAULT=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# RAG / Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=sentient-content
EMBEDDING_MODEL=text-embedding-3-small

# Admin console (optional — comma-separated; empty = allow all IPs in dev)
ADMIN_ALLOWED_IPS=
ADMIN_2FA_ISSUER=Sentient
ADMIN_UI_URL=https://backend-production-2df9.up.railway.app/admin/ui
# Admin invite emails (optional — without SMTP, invite link is shown in owner UI only)
ADMIN_INVITE_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Backward-compatible alias if older code still references this key name.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Per-course Price IDs — required for checkout until course_products is seeded in Supabase
STRIPE_PRICE_STARTER_BUNDLE=
STRIPE_PRICE_WEEK_ZERO_RESET=
STRIPE_PRICE_DEEP_CALM=
STRIPE_PRICE_FOCUS_DISCIPLINE=
