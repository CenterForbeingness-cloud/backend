# Copy this file to .env and fill in values
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
PORT=8000

# Supabase
SUPABASE_URL=
# Use service-role key only for backend — NEVER expose in frontend
SUPABASE_KEY=
SUPABASE_DB_URL=
SUPABASE_JWT_SECRET=

# Auth / security
AUTH_ENFORCED=false
# Comma-separated allowed origins (leave empty to allow all in dev)
CORS_ORIGINS=

# RAG
RAG_ENABLED=false
RAG_TOP_K=3

# Auth
# Get this from Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
# Set true to require valid Bearer tokens on protected endpoints.
# Keep false for local development while wiring auth.
AUTH_ENFORCED=false

# RAG / Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=sentient-content
EMBEDDING_MODEL=text-embedding-3-small
